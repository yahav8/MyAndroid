<resources>
    <style name="Theme.MyFinal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/base1</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/base3</item>
        <item name="android:windowBackground">@color/base5</item>
        <item name="android:textColorPrimary">?android:attr/textColorPrimary</item>
        <item name="android:buttonStyle">@style/Widget.MyApp.Button</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.MyApp.Title</item>
    </style>

    <style name="Widget.MyApp.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="colorAccent">@color/base2</item>
        <item name="android:textSize">20dp</item>
    </style>

    <style name="TextAppearance.MyApp.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">45sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="TextAppearance.MyApp.RegularText" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textSize">16sp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="ProfileLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#757575</item>
        <item name="android:layout_marginTop">8dp</item>
    </style>

    <style name="ProfileValueStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">4dp</item>
    </style>
</resources>