<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/base5"
    tools:context=".Start.SignUp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/base1"
        app:navigationIcon="@android:drawable/ic_menu_revert" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layoutDirection="rtl">

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:text="הרשמה למערכת"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark" />

            <EditText android:id="@+id/nameInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:hint="שם מלא" android:padding="12dp" android:textSize="16sp" android:inputType="textPersonName" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/idInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:hint="תעודת זהות" android:inputType="number" android:padding="12dp" android:textSize="16sp" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/emailInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:hint="אימייל" android:inputType="textEmailAddress" android:padding="12dp" android:textSize="16sp" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/phoneInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:hint="מספר טלפון" android:inputType="phone" android:padding="12dp" android:textSize="16sp" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/rankInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:hint="בחר דרגה" android:padding="12dp" android:textSize="16sp" android:focusable="false" android:clickable="true" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/courseInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:hint="מספר קורס" android:padding="12dp" android:textSize="16sp" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/releaseDateInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="10dp" android:background="@android:drawable/edit_text" android:focusable="false" android:clickable="true" android:hint="תאריך שחרור" android:padding="12dp" android:textSize="16sp" android:gravity="right|center_vertical"/>
            <EditText android:id="@+id/passwordInput" android:layout_width="match_parent" android:layout_height="55dp" android:layout_marginBottom="20dp" android:background="@android:drawable/edit_text" android:hint="סיסמה (לפחות 6 תווים)" android:inputType="textPassword" android:padding="12dp" android:textSize="16sp" android:gravity="right|center_vertical"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:background="@color/base3"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:text="בחר אוואטר אישי:"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/uploadImagePlaceholder"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/p1"
                    android:scaleType="centerCrop"
                    android:padding="2dp"
                    android:background="@color/primary_light" />
            </LinearLayout>

            <Button android:id="@+id/registerButton" android:layout_width="match_parent" android:layout_height="55dp" android:text="סיום הרשמה" android:textSize="18sp" android:backgroundTint="@color/base2" android:textColor="@android:color/white" android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnGoToLogIn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="כבר רשום? להתחברות" android:backgroundTint="@android:color/transparent" android:textColor="@android:color/holo_blue_dark" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout android:layout_width="match_parent" android:layout_height="60dp">
        <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/base1" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="center" android:gravity="center" android:text="© מערך הבקרים 2026" android:textColor="@android:color/white" />
    </FrameLayout>
</LinearLayout>