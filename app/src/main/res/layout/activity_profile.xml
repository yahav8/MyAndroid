<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/base5"
    tools:context=".Profile">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@color/base1"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            android:layoutDirection="ltr" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">

                    <LinearLayout
                        android:id="@+id/llInfoBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="65dp"
                        android:background="@color/base3"
                        android:orientation="vertical"
                        android:paddingTop="75dp"
                        android:paddingBottom="20dp"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_horizontal">

                        <TextView
                            android:id="@+id/tvProfName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="טוען שם..."
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_dark"
                            android:layout_marginBottom="15dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="קורס:"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProfCourse"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="דרגה:"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProfRank"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ת.ז:"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProfId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="טלפון:"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProfPhone"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="מייל:"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProfEmail"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---"
                                    android:layout_marginBottom="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="שחרור:"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvProfDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="---" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivProfImage"
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:layout_centerHorizontal="true"
                        android:elevation="10dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/p1" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvMyPostsTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="הפוסטים שלי"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="24dp"
                    android:layout_marginRight="16dp"
                    android:textColor="@color/primary_dark"
                    android:gravity="right"/>

                <LinearLayout
                    android:id="@+id/llPostsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="70dp">

            <View
                android:id="@+id/vFooterBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/base1" />

            <TextView
                android:id="@+id/tvFooterCopyright"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="© מערך הבקרים 2026"
                android:textColor="#FFFFFF"
                android:background="#2B3149"
                android:gravity="center"
                android:layout_gravity="center" />

            <ImageView
                android:id="@+id/ivWifiIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="20dp"
                android:src="@drawable/wifi"
                app:tint="@android:color/white"/>
        </FrameLayout>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardFab"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:layout_marginLeft="20dp"
        android:layout_marginBottom="85dp"
        app:cardCornerRadius="32.5dp"
        app:cardBackgroundColor="@color/base2"
        app:cardElevation="12dp">

        <ImageView
            android:id="@+id/btnAddPost"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_input_add"
            android:padding="12dp"
            app:tint="@android:color/white"
            android:scaleType="fitCenter" />
    </androidx.cardview.widget.CardView>

</RelativeLayout>